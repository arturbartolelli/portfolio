---
import Layout from "../../layouts/Layout.astro";
import { ui, skillsData, experienceData } from "../../i18n/ui";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

export function getStaticPaths() {
	return [{ params: { lang: "en" } }, { params: { lang: "pt" } }];
}

const { lang } = Astro.params;
const t = useTranslations(lang as any);

const currentSkills = skillsData[lang as keyof typeof skillsData];
const currentExperience = experienceData[lang as keyof typeof experienceData];
---

<Layout title="Full-Stack Engineer">
	<!-- Hero Section -->
	<section
		class="min-h-[90vh] flex flex-col justify-center px-6 max-w-7xl mx-auto relative overflow-hidden"
	>
		<div
			class="absolute -top-24 -right-24 w-96 h-96 bg-amazon-green-pastel/5 blur-[120px] rounded-full"
		>
		</div>
		<div
			class="absolute top-1/2 -left-24 w-64 h-64 bg-amazon-green-deep/10 blur-[100px] rounded-full"
		>
		</div>

		<div class="relative z-10">
			<span
				class="font-mono text-amazon-green-pastel mb-6 block tracking-widest uppercase text-xs opacity-reveal"
				>Full-Stack Engineer</span
			>
			<h1
				class="font-display text-5xl md:text-8xl font-bold leading-[0.9] tracking-tighter mb-8 opacity-reveal"
			>
				{t("hero.headline")}
			</h1>
			<p
				class="max-w-xl text-amazon-beige/60 text-lg md:text-xl mb-12 leading-relaxed opacity-reveal"
			>
				{t("hero.subheadline")}
			</p>

			<div class="flex flex-wrap gap-4 opacity-reveal">
				<a
					href="https://github.com/arturbartolelli"
					class="bg-amazon-green-pastel text-amazon-black px-8 py-4 rounded-full font-bold hover:scale-105 transition-transform"
					>{t("hero.cta.github")}</a
				>
				<a
					href="/portfolio/Curriculo_Artur_Bartolelli_2.pdf"
					download="Curriculo_Artur_Bartolelli.pdf"
					class="border border-amazon-green-deep text-amazon-sand px-8 py-4 rounded-full font-bold hover:bg-amazon-green-deep/20 transition-all font-mono text-sm"
				>
					{t("hero.cta.cv")}
				</a>
			</div>
		</div>

		<div
			class="absolute bottom-10 left-6 flex items-center gap-4 font-mono text-[10px] text-amazon-beige/40 uppercase tracking-widest group"
		>
			<span class="opacity-70">
				{lang === "pt" ? "Pressione " : "Press "}
				<kbd
					class="bg-amazon-forest border border-amazon-green-deep px-2 py-1 rounded text-amazon-green-pastel font-bold"
					>Ctrl + K</kbd
				>
				{
					lang === "pt"
						? " ou clique para abrir o terminal"
						: " or click to open terminal"
				}
			</span>
			<button
				id="terminal-trigger"
				class="bg-amazon-green-deep/20 hover:bg-amazon-green-deep/40 border border-amazon-green-deep/30 px-3 py-1.5 rounded-md text-[9px] text-amazon-green-pastel transition-all flex items-center gap-2"
			>
				<span
					class="w-1.5 h-1.5 rounded-full bg-amazon-green-pastel animate-pulse"
				></span>
				{t("terminal.toggle")}
			</button>
		</div>
	</section>

	<!-- About Section -->
	<section id="about" class="py-32 px-6 max-w-7xl mx-auto">
		<div class="grid md:grid-cols-2 gap-16 items-center">
			<div class="opacity-reveal">
				<h2 class="font-display text-4xl md:text-5xl font-bold mb-8">
					{t("about.title")}
				</h2>
				<p class="text-amazon-beige/70 text-lg leading-relaxed mb-6">
					{t("about.paragraph")}
				</p>
				<div class="font-mono text-sm text-amazon-green-pastel">
					> {t("about.education")}
				</div>
			</div>
			<div class="relative opacity-reveal">
				<div
					class="aspect-square bg-amazon-forest border border-amazon-green-deep rounded-2xl overflow-hidden group shadow-[0_0_50px_-12px_rgba(163,177,138,0.1)]"
				>
					<div
						class="absolute inset-0 bg-gradient-to-br from-amazon-green-pastel/10 via-transparent to-transparent opacity-50 group-hover:opacity-100 transition-all duration-700"
					>
					</div>
					<div
						class="p-8 h-full flex flex-col justify-end relative z-10"
					>
						<span
							class="text-stroke text-7xl font-display font-bold block mb-4 tracking-tighter uppercase"
							>{t("about.engineer_title")}</span
						>
						<p
							class="font-mono text-xs text-amazon-beige/40 leading-relaxed uppercase tracking-wider"
						>
							{t("about.engineer_subtitle")}
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Skills Grid -->
	<section
		class="py-32 px-6 max-w-7xl mx-auto border-t border-amazon-green-deep/10"
	>
		<h2
			class="font-display text-4xl md:text-5xl font-bold mb-16 opacity-reveal"
		>
			{t("skills.title")}
		</h2>
		<div class="grid md:grid-cols-3 gap-12">
			{
				currentSkills.map((cat) => (
					<div class="opacity-reveal">
						<h3 class="font-mono text-amazon-green-pastel text-xs uppercase tracking-widest mb-6">
							{cat.name}
						</h3>
						<ul class="space-y-4">
							{cat.items.map((skill) => (
								<li class="flex items-center gap-3 text-amazon-sand group cursor-default">
									<span class="w-1.5 h-1.5 rounded-full bg-amazon-green-deep group-hover:bg-amazon-green-pastel transition-colors" />
									<span class="font-display font-medium text-lg">
										{skill}
									</span>
								</li>
							))}
						</ul>
					</div>
				))
			}
		</div>
	</section>

	<!-- Experience Accordion -->
	<section id="experience" class="py-32 px-6 max-w-7xl mx-auto">
		<h2
			class="font-display text-4xl md:text-5xl font-bold mb-20 text-center opacity-reveal"
		>
			{t("exp.title")}
		</h2>
		<div class="space-y-6">
			{
				currentExperience.map((exp, i) => (
					<div
						class="accordion-item group border border-amazon-green-deep/20 rounded-2xl hover:bg-amazon-forest/30 transition-all duration-300"
						data-open="false"
					>
						<button class="accordion-trigger w-full flex flex-col md:flex-row md:items-center justify-between p-8 text-left focus:outline-none cursor-pointer">
							<div class="flex flex-col gap-1">
								<span class="font-mono text-amazon-green-pastel text-xs tracking-widest">
									{exp.period}
								</span>
								<h3 class="font-display text-2xl font-bold group-hover:text-amazon-green-pastel transition-colors">
									{exp.company} —{" "}
									<span class="text-amazon-beige/60 font-medium text-lg">
										{exp.title}
									</span>
								</h3>
								<p class="text-amazon-beige/40 text-sm mt-1">
									{exp.shortDescription}
								</p>
							</div>
							<div class="mt-4 md:mt-0 chevron transition-transform duration-500 text-amazon-green-deep group-hover:text-amazon-green-pastel">
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="24"
									height="24"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
								>
									<path d="m6 9 6 6 6-6" />
								</svg>
							</div>
						</button>

						<div class="accordion-content grid transition-all duration-500 ease-in-out grid-rows-[0fr] opacity-0 overflow-hidden">
							<div class="min-h-0">
								<div class="px-8 pb-8 pt-2 border-t border-amazon-green-deep/10">
									<ul class="space-y-4">
										{exp.responsibilities.map((resp) => (
											<li class="flex gap-4 text-amazon-beige/60 text-sm leading-relaxed">
												<span class="text-amazon-green-pastel opacity-50">
													▹
												</span>
												{resp}
											</li>
										))}
									</ul>
								</div>
							</div>
						</div>
					</div>
				))
			}
		</div>
	</section>

	<script>
		const setupAccordion = () => {
			const items = document.querySelectorAll(".accordion-item");

			items.forEach((item) => {
				const trigger = item.querySelector(".accordion-trigger");

				// Remove old listeners if any (though in standard Astro scripts this isn't always needed, it's safer)
				const newTrigger = trigger?.cloneNode(true);
				if (trigger && newTrigger) {
					trigger.parentNode?.replaceChild(newTrigger, trigger);

					newTrigger.addEventListener("click", () => {
						const isOpen =
							item.getAttribute("data-open") === "true";

						const closeItem = (el: Element) => {
							el.setAttribute("data-open", "false");
							const c = el.querySelector(".accordion-content");
							const ch = el.querySelector(".chevron");
							if (c) {
								c.classList.remove(
									"grid-rows-[1fr]",
									"opacity-100",
								);
								c.classList.add("grid-rows-[0fr]", "opacity-0");
							}
							ch?.classList.remove("rotate-180");
						};

						const openItem = (el: Element) => {
							el.setAttribute("data-open", "true");
							const c = el.querySelector(".accordion-content");
							const ch = el.querySelector(".chevron");
							if (c) {
								c.classList.remove(
									"grid-rows-[0fr]",
									"opacity-0",
								);
								c.classList.add(
									"grid-rows-[1fr]",
									"opacity-100",
								);
							}
							ch?.classList.add("rotate-180");
						};

						if (isOpen) {
							closeItem(item);
						} else {
							items.forEach((otherItem) => {
								if (otherItem !== item) closeItem(otherItem);
							});
							openItem(item);
						}
					});
				}
			});
		};

		// Terminal Trigger
		document
			.getElementById("terminal-trigger")
			?.addEventListener("click", () => {
				window.dispatchEvent(new CustomEvent("toggle-terminal"));
			});

		// Run initially and on page load
		document.addEventListener("astro:page-load", () => {
			setupAccordion();
		});
		setupAccordion();
	</script>

	<!-- Open Source -->
	<section
		class="py-32 px-6 max-w-7xl mx-auto border-t border-amazon-green-deep/10"
	>
		<h2
			class="font-display text-4xl md:text-5xl font-bold mb-20 opacity-reveal"
		>
			{t("open.title")}
		</h2>
		<div class="grid md:grid-cols-2 gap-8">
			<a
				href="https://github.com/verbeux-ai/whatsapp-business"
				class="group p-8 bg-amazon-forest border border-amazon-green-deep/20 rounded-2xl hover:border-amazon-green-pastel transition-all opacity-reveal"
			>
				<div class="flex justify-between items-start mb-8">
					<div
						class="p-3 bg-amazon-green-deep/30 rounded-lg text-amazon-green-pastel"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="24"
							height="24"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							><path
								d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
							></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
						>
					</div>
					<span
						class="font-mono text-[10px] text-amazon-green-pastel bg-amazon-green-deep/20 px-2 py-1 rounded"
						>GO</span
					>
				</div>
				<h3 class="font-display text-2xl font-bold mb-4">
					whatsapp-business
				</h3>
				<p class="text-amazon-beige/40 text-sm leading-relaxed">
					Golang library for Meta WhatsApp Business API integration.
				</p>
			</a>
			<a
				href="https://github.com/verbeux-ai/whatsmiau"
				class="group p-8 bg-amazon-forest border border-amazon-green-deep/20 rounded-2xl hover:border-amazon-green-pastel transition-all opacity-reveal"
			>
				<div class="flex justify-between items-start mb-8">
					<div
						class="p-3 bg-amazon-green-deep/30 rounded-lg text-amazon-green-pastel"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="24"
							height="24"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							><path
								d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
							></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
						>
					</div>
					<span
						class="font-mono text-[10px] text-amazon-green-pastel bg-amazon-green-deep/20 px-2 py-1 rounded"
						>GO</span
					>
				</div>
				<h3 class="font-display text-2xl font-bold mb-4">whatsmiau</h3>
				<p class="text-amazon-beige/40 text-sm leading-relaxed">
					Golang library for WhatsApp Multi-Device integration. High
					performance and easy to use.
				</p>
			</a>
			<a
				href="https://github.com/verbeux-ai/evolution-client-go"
				class="group p-8 bg-amazon-forest border border-amazon-green-deep/20 rounded-2xl hover:border-amazon-green-pastel transition-all opacity-reveal"
			>
				<div class="flex justify-between items-start mb-8">
					<div
						class="p-3 bg-amazon-green-deep/30 rounded-lg text-amazon-green-pastel"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="24"
							height="24"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							><path
								d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
							></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
						>
					</div>
					<span
						class="font-mono text-[10px] text-amazon-green-pastel bg-amazon-green-deep/20 px-2 py-1 rounded"
						>GO</span
					>
				</div>
				<h3 class="font-display text-2xl font-bold mb-4">
					evolution-client-go
				</h3>
				<p class="text-amazon-beige/40 text-sm leading-relaxed">
					Official Go SDK for Evolution API. Scalable and type-safe
					implementation.
				</p>
			</a>
		</div>
	</section>
</Layout>
