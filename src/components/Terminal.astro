---
const { lang } = Astro.props;
---

<div id="terminal-overlay" class="fixed inset-0 bg-amazon-black/90 backdrop-blur-sm z-[100] hidden items-center justify-center p-4">
  <div class="bg-amazon-forest border border-amazon-green-deep w-full max-w-2xl rounded-lg shadow-2xl overflow-hidden font-mono text-sm">
    <div class="bg-amazon-green-deep/30 px-4 py-2 flex items-center justify-between border-b border-amazon-green-deep">
      <div class="flex gap-2">
        <div id="terminal-close" class="w-3 h-3 rounded-full bg-red-500/50 cursor-pointer hover:bg-red-500 transition-colors"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-500/50"></div>
        <div class="w-3 h-3 rounded-full bg-amazon-green-pastel/50"></div>
      </div>
      <span class="text-amazon-green-pastel/60 text-xs">artur@portfolio: ~</span>
    </div>
    <div id="terminal-content" class="h-80 overflow-y-auto p-4 text-amazon-beige space-y-2">
      <div class="text-amazon-green-pastel">
        {lang === 'pt' ? 'Bem-vindo ao Shell do Artur. Digite \'help\' para ver os comandos.' : 'Welcome to Artur\'s Shell. Type \'help\' to see available commands.'}
      </div>
    </div>
    <div class="p-4 pt-0 flex gap-2">
      <span class="text-amazon-green-pastel">λ</span>
      <input type="text" id="terminal-input" class="bg-transparent border-none outline-none flex-1 text-amazon-beige" autofocus />
    </div>
  </div>
</div>

<script>
  import { gsap } from 'gsap';

  const overlay = document.getElementById('terminal-overlay');
  const closeBtn = document.getElementById('terminal-close');
  const input = document.getElementById('terminal-input') as HTMLInputElement;
  const content = document.getElementById('terminal-content');

  let isOpen = false;

  const commands: Record<string, string> = {
    help: 'Available commands: about, skills, exp, contact, cv, clear, exit',
    about: 'Artur Bartolelli - Full-Stack Engineer. Specialized in Scalable SaaS & CRM architectures.',
    skills: 'Go, Java, Node.js, React, Next.js, PostgreSQL, Docker, GCP, AWS (Certified).',
    exp: 'ABM TI (Lead), Verboo (Product Engineer), Luga Energy (Full-Stack).',
    contact: 'Email: arturbartonelli@gmail.com | GitHub: @arturbartolelli',
    cv: 'Downloading resume...',
    clear: '',
  };

  function toggleTerminal() {
    isOpen = !isOpen;
    if (isOpen) {
      overlay?.classList.remove('hidden');
      overlay?.classList.add('flex');
      gsap.fromTo(overlay, { opacity: 0, scale: 0.9 }, { opacity: 1, scale: 1, duration: 0.3, ease: 'power2.out' });
      input?.focus();
    } else {
      gsap.to(overlay, { opacity: 0, scale: 0.9, duration: 0.2, onComplete: () => overlay?.classList.add('hidden') });
    }
  }

  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) toggleTerminal();
  });

  closeBtn?.addEventListener('click', () => {
    toggleTerminal();
  });

  window.addEventListener('toggle-terminal', () => {
    toggleTerminal();
  });

  window.addEventListener('keydown', (e) => {
    if ((e.ctrlKey && e.key === 'k') || e.key === '~') {
      e.preventDefault();
      toggleTerminal();
    }
    if (e.key === 'Escape' && isOpen) toggleTerminal();
  });

  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      const val = input.value.trim().toLowerCase();
      const output = document.createElement('div');
      output.innerHTML = `<span class="text-amazon-green-pastel">λ ${val}</span><br/>${commands[val] || `Command not found: ${val}`}`;
      
      if (val === 'clear') {
        if (content) content.innerHTML = '';
      } else if (val === 'exit') {
        toggleTerminal();
      } else {
        content?.appendChild(output);
      }
      
      input.value = '';
      content?.scrollTo(0, content.scrollHeight);
    }
  });
</script>
